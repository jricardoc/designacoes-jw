# Backend (Node/Express/Prisma). Copie para backend/.env em dev local.
# Em producao (EasyPanel), configure estas variaveis na plataforma.

# Conexao com o PostgreSQL
DATABASE_URL=postgres://admin:senha@localhost:5432/designacoes

# OBRIGATORIO: sem isso o servidor nao inicia (nao ha fallback).
# Gere um segredo forte, ex.: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-forte-aleatorio

# Opcional: validade do token (padrao 7d)
JWT_EXPIRES_IN=7d

# Porta da API (padrao 3001)
PORT=3001

# Origem do frontend liberada no CORS
FRONTEND_URL=http://localhost:5173

# Senha inicial do admin no primeiro boot (padrao jw1010). Troque no primeiro acesso.
ADMIN_SEED_PASSWORD=jw1010
