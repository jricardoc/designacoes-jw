FROM node:20-alpine
WORKDIR /app
COPY package*.json ./

# AJUSTE: Removi o --production para garantir que ferramentas de build/TS instalem
RUN npm install 

COPY . .
RUN npx prisma generate
EXPOSE 3001
# Aplica o schema ao banco no boot antes de subir a API (sem isso, um deploy
# limpo inicia sem as tabelas). Idempotente.
CMD ["sh", "-c", "npx prisma db push && npm start"]