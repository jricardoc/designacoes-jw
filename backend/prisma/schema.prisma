generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Quadro de Designacoes Mensal (um por mes/ano)
model Quadro {
  id           Int           @id @default(autoincrement())
  mes          Int           // 1-12
  ano          Int           // 2026
  titulo       String        // "Quadro de Designacoes JANEIRO 2026"
  status       String        @default("rascunho") // rascunho, publicado, arquivado
  designacoes  Designacao[]
  historicos   Historico[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  @@unique([mes, ano])
}

// Designacoes pertencem a um Quadro especifico
model Designacao {
  id        Int      @id @default(autoincrement())
  quadroId  Int
  quadro    Quadro   @relation(fields: [quadroId], references: [id], onDelete: Cascade)
  data      String
  dia       String
  funcao    String
  irmao1    String
  irmao2    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Historico de todas as modificacoes
model Historico {
  id          Int      @id @default(autoincrement())
  quadroId    Int
  quadro      Quadro   @relation(fields: [quadroId], references: [id], onDelete: Cascade)
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  acao        String   // "criou", "editou", "excluiu", "publicou", "arquivou"
  descricao   String   // Descricao legivel
  campo       String?  // Campo modificado (irmao1, irmao2, data, dia)
  valorAntigo String?  // Valor anterior
  valorNovo   String?  // Novo valor
  designacaoInfo String? // Info da designacao (data + funcao)
  createdAt   DateTime @default(now())
}

// Configuracoes gerais do sistema
model Config {
  id        Int      @id @default(autoincrement())
  titulo    String
  subtitulo String
  mes       String
  updatedAt DateTime @updatedAt
}

// Usuario para autenticacao (login por nickname)
model Usuario {
  id         Int         @id @default(autoincrement())
  nickname   String      @unique
  senha      String
  nome       String
  isAdmin    Boolean     @default(false)
  historicos Historico[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// Cadastro de irmaos com suas funcoes
model Irmao {
  id                 Int                @id @default(autoincrement())
  nome               String             @unique
  funcoes            String[]
  nivelAudioVideo    String             @default("experiente") // "experiente" ou "treinando"
  ativo              Boolean            @default(true)
  indisponibilidades Indisponibilidade[]
  dirigenteSaidas    DirigenteSaidaCampo[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

// Datas em que o irmao nao esta disponivel
model Indisponibilidade {
  id        Int      @id @default(autoincrement())
  irmaoId   Int
  irmao     Irmao    @relation(fields: [irmaoId], references: [id], onDelete: Cascade)
  data      String
  motivo    String?
  createdAt DateTime @default(now())
  
  @@unique([irmaoId, data])
}

// NOVO: Modelos para Reuniões Importadas via Excel
model Reuniao {
  id        Int      @id @default(autoincrement())
  mes       Int      // 1-12
  ano       Int      // 2026
  semanas   SemanaReuniao[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mes, ano])
}

model SemanaReuniao {
  id             Int      @id @default(autoincrement())
  reuniaoId      Int
  reuniao        Reuniao  @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  
  // Dados Gerais da Semana
  faixaData      String   // Ex: "Março 02 - 08"
  dataReuniao    String?  // Ex: "05/03/2026"
  leituraSemanal String?  // Ex: "Ísaias 41 - 42"
  
  // Cabeçalho / Presidente
  presidente     String?
  conselheiroB   String?
  oracaoInicial  String?
  oracaoFinal    String?
  
  // Canticos e Tempos
  canticoInicial String?
  canticoMeio    String?
  canticoFinal   String?
  
  // Partes da Reunião (JSON ou campos específicos - usaremos campos para facilitar)
  // Tesouros
  tesouro1_titulo   String?
  tesouro1_irmao    String?
  tesouro2_titulo   String?
  tesouro2_irmao    String?
  tesouro3_titulo   String?
  tesouro3_salaB    String?
  tesouro3_principal String?
  
  // Ministério
  ministerio1_titulo String?
  ministerio1_salaB  String?
  ministerio1_principal String?
  ministerio2_titulo String?
  ministerio2_salaB  String?
  ministerio2_principal String?
  ministerio3_titulo String?
  ministerio3_salaB  String?
  ministerio3_principal String?
  ministerio4_titulo String?
  ministerio4_salaB  String?
  ministerio4_principal String?

  // Vida Cristã
  vidaCrista1_titulo String?
  vidaCrista1_irmao  String?
  vidaCrista2_titulo String?
  vidaCrista2_irmao  String?
  
  // Estudo Bíblico
  estudoBiblico_dirigente String?
  estudoBiblico_leitor    String?
  
  // Final de Semana
  fds_presidente String?
  fds_tema       String?
  fds_orador     String?
  fds_congregacao String?
  fds_leitor     String?
  
  // Designações Mecânicas (Meio de Semana)
  mecanica_audioVideo String?
  mecanica_indicadores String?
  mecanica_microfone  String?
  
  // Designações Mecânicas (Final de Semana)
  fds_mecanica_audioVideo String?
  fds_mecanica_indicadores String?
  fds_mecanica_microfone  String?
  fds_mecanica_portao     String?
  
  // Limpeza
  limpeza                 String?
  
  createdAt      DateTime @default(now())
}

// Configuração das Saídas de Campo (locais/horários por dia da semana)
model SaidaCampo {
  id        Int      @id @default(autoincrement())
  diaSemana String   // "segunda", "terca", "quarta", "quinta", "sexta", "sabado"
  turno     Int      @default(1) // 1 para dias normais, 1-4 para sábado
  local     String   // "Ex-Combatentes - Casa dos irmãos Walney e Olga"
  horario   String   // "08:45"
  ativo     Boolean  @default(true)
  dirigentesDisponiveis DirigenteSaidaCampo[]
  escalas   EscalaDirigente[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Relação N:N - Quais irmãos podem dirigir em cada saída de campo
model DirigenteSaidaCampo {
  id          Int       @id @default(autoincrement())
  irmaoId     Int
  irmao       Irmao     @relation(fields: [irmaoId], references: [id], onDelete: Cascade)
  saidaCampoId Int
  saidaCampo  SaidaCampo @relation(fields: [saidaCampoId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  
  @@unique([irmaoId, saidaCampoId])
}

// Quadro mensal da Escala de Dirigentes
model QuadroDirigente {
  id        Int                @id @default(autoincrement())
  mes       Int                // 1-12
  ano       Int                // 2026
  titulo    String
  status    String             @default("rascunho")
  escalas   EscalaDirigente[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  
  @@unique([mes, ano])
}

// Escala: cada dia/saída com dirigente principal e substituto
model EscalaDirigente {
  id              Int             @id @default(autoincrement())
  quadroId        Int
  quadro          QuadroDirigente @relation(fields: [quadroId], references: [id], onDelete: Cascade)
  saidaCampoId    Int
  saidaCampo      SaidaCampo      @relation(fields: [saidaCampoId], references: [id], onDelete: Cascade)
  data            String          // "02/06" (dia/mês)
  dia             String          // "Segunda", "Terça", etc.
  principal       String          @default("") // Nome do dirigente principal
  substituto      String          @default("") // Nome do substituto
  removido        Boolean         @default(false) // Para remover dias
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
