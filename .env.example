# Variaveis usadas pelo docker-compose.yml (dev local).
# Copie para .env e ajuste. Em producao, configure na plataforma (EasyPanel).

# Banco de dados
POSTGRES_USER=admin
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=designacoes

# Backend
# Gere um segredo forte, ex.: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-forte-aleatorio
FRONTEND_URL=http://localhost:5173
# Senha inicial do usuario admin criado no primeiro boot (troque no primeiro acesso)
ADMIN_SEED_PASSWORD=jw1010

# Frontend
VITE_API_URL=http://localhost:3001
